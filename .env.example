# === robot-arm-service config (sao chép thành .env, sửa giá trị thật) ===

# DRY_RUN=true → chạy KHÔNG cần robot/AI thật (mô phỏng, để test logic)
DRY_RUN=true

# --- 3 cánh tay (mỗi con 1 IP RIÊNG — đổi qua Web UI/Pendant, xem doc §13.3) ---
ARM_S1_IP=192.168.58.2
ARM_S2_IP=192.168.58.3
ARM_S3_IP=192.168.58.4
ARM_RPC_PORT=20003

# Tay nào phục vụ Category nào (Manager config; khớp Dish.CategoryId)
ARM_S1_CATEGORY=COM      # cơm
ARM_S2_CATEGORY=MAN      # món mặn
ARM_S3_CATEGORY=CANH     # canh

# --- Backend (SignalR nối RA) ---
BACKEND_HUB_URL=https://your-backend.example.com/hubs/robot
BACKEND_TOKEN=           # JWT/secret — KHÔNG hardcode trong code

# --- Service API ---
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# --- Vision ---
YOLO_MODEL_PATH=models/food_v1.pt
QR_VERIFY_ENABLED=true
